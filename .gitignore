cat > .gitignore <<EOL
# ── Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments
venv/
.venv/
env/
.env
.env.bak
.env.example

# ── Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Outputs
outputs/
!outputs/models/best_model.pkl
!outputs/models/preprocessor.pkl
!outputs/models/residual_std.json

# ── Dataset
Flight_Price_Dataset_of_Bangladesh.csv

# ── Airflow logs
logs/

# ── IDE / OS
.vscode/
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ── Temporary / debug files
*.log
*.tmp
*.bak
EOL