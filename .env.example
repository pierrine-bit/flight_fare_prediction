# .env.example — copy this file to .env and fill in your credentials
# Used by Docker Compose and Airflow for email notifications.

# ── Airflow core ───────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
FERNET_KEY=your-fernet-key-here          # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__API_AUTH__JWT_SECRET=your-jwt-secret-here

# ── SMTP (used by send_email() in the DAG for success/failure alerts) ──────────
# Airflow reads these as AIRFLOW__SMTP__* and wires them into its smtp_default connection.
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_USER=your.email@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your-app-password-here   # Gmail: use an App Password, not your account password
AIRFLOW__SMTP__SMTP_MAIL_FROM=your.email@gmail.com

# ── Data path override (optional — default resolves from src/config.py) ────────
# DATA_PATH=/path/to/Flight_Price_Dataset_of_Bangladesh.csv
